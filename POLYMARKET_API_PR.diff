@@ -0,0 +1,73 @@
+package polymarket
+
+import (
+	"math"
+	"strconv"
+	"time"
+
+	"github.com/turbine/clob-api/pkg/types"
+)
+
+type PolymarketMarketResponse struct {
+	ID          string  `json:"id"`
+	ChainID     int64   `json:"chainId"`
+	Question    string  `json:"question"`
+	Description string  `json:"description,omitempty"`
+	Category    string  `json:"category,omitempty"`
+	Expiration  int64   `json:"expiration"`
+	Resolved    bool    `json:"resolved"`
+	Volume      int64   `json:"volume"`
+	Provider    string  `json:"provider"`
+	Tokens      []Token `json:"tokens,omitempty"`
+}
+
+func ConvertMarketToResponse(pm PolymarketMarket) PolymarketMarketResponse {
+	var expiration int64
+	if pm.EndDate != "" {
+		if t, err := time.Parse(time.RFC3339, pm.EndDate); err == nil {
+			expiration = t.Unix()
+		}
+	}
+
+	volume := int64(math.Round(pm.Volume * 1e6))
+
+	return PolymarketMarketResponse{
+		ID:          pm.ConditionID,
+		ChainID:     137,
+		Question:    pm.Question,
+		Description: pm.Description,
+		Category:    pm.Category,
+		Expiration:  expiration,
+		Resolved:    pm.Closed,
+		Volume:      volume,
+		Provider:    "polymarket",
+		Tokens:      pm.Tokens,
+	}
+}
+
+func ConvertOrderBookToSnapshot(marketID string, ob OrderBookResponse) types.OrderBookSnapshot {
+	bids := make([]types.PriceLevel, len(ob.Bids))
+	for i, b := range ob.Bids {
+		bids[i] = parsePriceLevel(b)
+	}
+
+	asks := make([]types.PriceLevel, len(ob.Asks))
+	for i, a := range ob.Asks {
+		asks[i] = parsePriceLevel(a)
+	}
+
+	return types.OrderBookSnapshot{
+		Bids: bids,
+		Asks: asks,
+	}
+}
+
+func parsePriceLevel(pl RawPriceLevel) types.PriceLevel {
+	price, _ := strconv.ParseFloat(pl.Price, 64)
+	size, _ := strconv.ParseFloat(pl.Size, 64)
+
+	return types.PriceLevel{
+		Price: uint64(math.Round(price * 1e6)),
+		Size:  uint64(math.Round(size * 1e6)),
+	}
+}
diff --git a/api/internal/polymarket/convert_test.go b/api/internal/polymarket/convert_test.go
new file mode 100644
index 0000000..fd3d714
--- /dev/null
+++ b/api/internal/polymarket/convert_test.go
@@ -0,0 +1,91 @@
+package polymarket
+
+import (
+	"testing"
+)
+
+func TestConvertMarketToResponse(t *testing.T) {
+	pm := PolymarketMarket{
+		ConditionID: "0xabc123",
+		Question:    "Will BTC hit 100k?",
+		Description: "Bitcoin price prediction",
+		Category:    "Crypto",
+		EndDate:     "2026-12-31T00:00:00Z",
+		Volume:      1500000.50,
+		Active:      true,
+		Closed:      false,
+		Tokens: []Token{
+			{TokenID: "token-yes", Outcome: "Yes", Price: 0.65},
+			{TokenID: "token-no", Outcome: "No", Price: 0.35},
+		},
+	}
+
+	resp := ConvertMarketToResponse(pm)
+
+	if resp.ID != "0xabc123" {
+		t.Errorf("ID = %s, want 0xabc123", resp.ID)
+	}
+	if resp.ChainID != 137 {
+		t.Errorf("ChainID = %d, want 137", resp.ChainID)
+	}
+	if resp.Question != "Will BTC hit 100k?" {
+		t.Errorf("Question = %s", resp.Question)
+	}
+	if resp.Description != "Bitcoin price prediction" {
+		t.Errorf("Description = %s", resp.Description)
+	}
+	if resp.Category != "Crypto" {
+		t.Errorf("Category = %s", resp.Category)
+	}
+	if resp.Resolved != false {
+		t.Error("Resolved should be false for active market")
+	}
+	if resp.Provider != "polymarket" {
+		t.Errorf("Provider = %s, want polymarket", resp.Provider)
+	}
+	if resp.Volume != 1_500_000_500_000 {
+		t.Errorf("Volume = %d, want 1500000500000", resp.Volume)
+	}
+}
+
+func TestConvertMarketToResponse_Closed(t *testing.T) {
+	pm := PolymarketMarket{
+		ConditionID: "0xdef456",
+		Question:    "Resolved market?",
+		Closed:      true,
+		Active:      false,
+	}
+
+	resp := ConvertMarketToResponse(pm)
+
+	if resp.Resolved != true {
+		t.Error("Resolved should be true for closed market")
+	}
+}
+
+func TestConvertOrderBookToSnapshot(t *testing.T) {
+	ob := OrderBookResponse{
+		Bids: []RawPriceLevel{
+			{Price: "0.60", Size: "100"},
+			{Price: "0.55", Size: "200"},
+		},
+		Asks: []RawPriceLevel{
+			{Price: "0.65", Size: "150"},
+		},
+	}
+
+	snapshot := ConvertOrderBookToSnapshot("market-123", ob)
+
+	if len(snapshot.Bids) != 2 {
+		t.Fatalf("expected 2 bids, got %d", len(snapshot.Bids))
+	}
+	if len(snapshot.Asks) != 1 {
+		t.Fatalf("expected 1 ask, got %d", len(snapshot.Asks))
+	}
+	if snapshot.Bids[0].Price != 600000 {
+		t.Errorf("bid price = %d, want 600000", snapshot.Bids[0].Price)
+	}
+	if snapshot.Asks[0].Size != 150000000 {
+		t.Errorf("ask size = %d, want 150000000", snapshot.Asks[0].Size)
+	}
+}
diff --git a/api/internal/polymarket/deposit.go b/api/internal/polymarket/deposit.go
new file mode 100644
index 0000000..4977daa
--- /dev/null
+++ b/api/internal/polymarket/deposit.go
@@ -0,0 +1,171 @@
+package polymarket
+
+import (
+	"context"
+	"crypto/ecdsa"
+	"fmt"
+	"math/big"
+	"sync"
+
+	"github.com/ethereum/go-ethereum"
+	"github.com/ethereum/go-ethereum/common"
+	"github.com/ethereum/go-ethereum/core/types"
+	"github.com/ethereum/go-ethereum/crypto"
+	"github.com/ethereum/go-ethereum/ethclient"
+)
+
+// PolygonDepositRelayer relays gasless USDC deposits to Polymarket on Polygon.
+// It uses Turbine's hot wallet to pay gas for two operations:
+//   1. USDC.permit() — grants Turbine's address allowance to spend user's USDC
+//   2. USDC.transferFrom() — moves USDC from user to Polymarket's deposit address
+type PolygonDepositRelayer struct {
+	client      *ethclient.Client
+	privateKey  *ecdsa.PrivateKey
+	chainID     *big.Int
+	usdcAddress common.Address
+	nonceMu     sync.Mutex
+}
+
+// NewPolygonDepositRelayer creates a deposit relayer using an existing Polygon RPC connection
+// and Turbine's hot wallet private key (same key used for settlement/relaying).
+func NewPolygonDepositRelayer(client *ethclient.Client, privateKey *ecdsa.PrivateKey, chainID int64, usdcAddress common.Address) *PolygonDepositRelayer {
+	return &PolygonDepositRelayer{
+		client:      client,
+		privateKey:  privateKey,
+		chainID:     big.NewInt(chainID),
+		usdcAddress: usdcAddress,
+	}
+}
+
+// RelayDeposit executes a gasless deposit in two on-chain transactions:
+//   1. permit: approve Turbine's relayer to spend user's USDC
+//   2. transferFrom: move USDC from user to Polymarket's deposit address
+func (r *PolygonDepositRelayer) RelayDeposit(ctx context.Context, req GaslessDepositRequest, depositAddress string) (string, error) {
+	ownerAddr := common.HexToAddress(req.Owner)
+	relayerAddr := crypto.PubkeyToAddress(r.privateKey.PublicKey)
+	depositAddr := common.HexToAddress(depositAddress)
+
+	amount := new(big.Int)
+	if _, ok := amount.SetString(req.Amount, 10); !ok {
+		return "", fmt.Errorf("invalid amount: %s", req.Amount)
+	}
+	if amount.Sign() <= 0 {
+		return "", fmt.Errorf("amount must be positive")
+	}
+
+	deadline := new(big.Int)
+	if _, ok := deadline.SetString(req.Deadline, 10); !ok {
+		return "", fmt.Errorf("invalid deadline: %s", req.Deadline)
+	}
+
+	// Validate signature components
+	if len(req.R) != 66 || len(req.S) != 66 {
+		return "", fmt.Errorf("invalid signature format (r: %d chars, s: %d chars, expected 66 each)", len(req.R), len(req.S))
+	}
+
+	rBytes := common.FromHex(req.R)
+	sBytes := common.FromHex(req.S)
+	var r32, s32 [32]byte
+	copy(r32[32-len(rBytes):], rBytes)
+	copy(s32[32-len(sBytes):], sBytes)
+
+	// Step 1: Submit permit (approve relayer to spend user's USDC)
+	permitData := encodePermit(ownerAddr, relayerAddr, amount, deadline, req.V, r32, s32)
+	_, err := r.sendTransaction(ctx, r.usdcAddress, permitData)
+	if err != nil {
+		return "", fmt.Errorf("permit failed: %w", err)
+	}
+
+	// Step 2: Submit transferFrom (move USDC from user to Polymarket deposit address)
+	transferData := encodeTransferFrom(ownerAddr, depositAddr, amount)
+	txHash, err := r.sendTransaction(ctx, r.usdcAddress, transferData)
+	if err != nil {
+		return "", fmt.Errorf("transferFrom failed: %w", err)
+	}
+
+	return txHash, nil
+}
+
+func (r *PolygonDepositRelayer) sendTransaction(ctx context.Context, to common.Address, data []byte) (string, error) {
+	r.nonceMu.Lock()
+	defer r.nonceMu.Unlock()
+
+	fromAddress := crypto.PubkeyToAddress(r.privateKey.PublicKey)
+	nonce, err := r.client.PendingNonceAt(ctx, fromAddress)
+	if err != nil {
+		return "", fmt.Errorf("failed to get nonce: %w", err)
+	}
+
+	gasLimit, err := r.client.EstimateGas(ctx, ethereum.CallMsg{
+		From: fromAddress,
+		To:   &to,
+		Data: data,
+	})
+	if err != nil {
+		// Fallback gas limit for permit/transfer
+		gasLimit = 100000
+	}
+
+	maxFeePerGas, err := r.client.SuggestGasPrice(ctx)
+	if err != nil {
+		return "", fmt.Errorf("failed to get gas price: %w", err)
+	}
+
+	gasTipCap, err := r.client.SuggestGasTipCap(ctx)
+	if err != nil {
+		return "", fmt.Errorf("failed to get gas tip: %w", err)
+	}
+	if gasTipCap.Cmp(maxFeePerGas) > 0 {
+		gasTipCap = new(big.Int).Set(maxFeePerGas)
+	}
+
+	tx := types.NewTx(&types.DynamicFeeTx{
+		ChainID:   r.chainID,
+		Nonce:     nonce,
+		GasTipCap: gasTipCap,
+		GasFeeCap: maxFeePerGas,
+		Gas:       gasLimit,
+		To:        &to,
+		Value:     big.NewInt(0),
+		Data:      data,
+	})
+
+	signedTx, err := types.SignTx(tx, types.LatestSignerForChainID(r.chainID), r.privateKey)
+	if err != nil {
+		return "", fmt.Errorf("failed to sign tx: %w", err)
+	}
+
+	if err := r.client.SendTransaction(ctx, signedTx); err != nil {
+		return "", fmt.Errorf("failed to send tx: %w", err)
+	}
+
+	return signedTx.Hash().Hex(), nil
+}
+
+// encodePermit encodes USDC.permit(owner, spender, value, deadline, v, r, s)
+func encodePermit(owner, spender common.Address, value, deadline *big.Int, v uint8, r, s [32]byte) []byte {
+	selector := crypto.Keccak256([]byte("permit(address,address,uint256,uint256,uint8,bytes32,bytes32)"))[:4]
+
+	data := make([]byte, 0, 4+7*32)
+	data = append(data, selector...)
+	data = append(data, common.LeftPadBytes(owner.Bytes(), 32)...)
+	data = append(data, common.LeftPadBytes(spender.Bytes(), 32)...)
+	data = append(data, common.LeftPadBytes(value.Bytes(), 32)...)
+	data = append(data, common.LeftPadBytes(deadline.Bytes(), 32)...)
+	data = append(data, common.LeftPadBytes([]byte{v}, 32)...)
+	data = append(data, r[:]...)
+	data = append(data, s[:]...)
+	return data
+}
+
+// encodeTransferFrom encodes USDC.transferFrom(from, to, amount)
+func encodeTransferFrom(from, to common.Address, amount *big.Int) []byte {
+	selector := crypto.Keccak256([]byte("transferFrom(address,address,uint256)"))[:4]
+
+	data := make([]byte, 0, 4+3*32)
+	data = append(data, selector...)
+	data = append(data, common.LeftPadBytes(from.Bytes(), 32)...)
+	data = append(data, common.LeftPadBytes(to.Bytes(), 32)...)
+	data = append(data, common.LeftPadBytes(amount.Bytes(), 32)...)
+	return data
+}
