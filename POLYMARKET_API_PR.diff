diff --git a/api/internal/polymarket/auth.go b/api/internal/polymarket/auth.go
new file mode 100644
index 0000000..5bd6754
--- /dev/null
+++ b/api/internal/polymarket/auth.go
@@ -0,0 +1,121 @@
+package polymarket
+
+import (
+	"encoding/json"
+	"fmt"
+	"io"
+	"log"
+	"net/http"
+)
+
+type AuthHandler struct {
+	polymarketBaseURL string
+	httpClient        *http.Client
+}
+
+func NewAuthHandler(polymarketBaseURL string) *AuthHandler {
+	return &AuthHandler{
+		polymarketBaseURL: polymarketBaseURL,
+		httpClient: &http.Client{
+			Timeout: SDKTimeout,
+		},
+	}
+}
+
+type AuthRequest struct {
+	Address   string `json:"address"`
+	Signature string `json:"signature"`
+	Timestamp string `json:"timestamp"`
+	Nonce     int    `json:"nonce"`
+}
+
+func (h *AuthHandler) CreateAPIKey(w http.ResponseWriter, r *http.Request) {
+	var req AuthRequest
+	r.Body = http.MaxBytesReader(w, r.Body, 1024)
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		respondError(w, http.StatusBadRequest, "invalid request body")
+		return
+	}
+
+	if req.Address == "" || req.Signature == "" || req.Timestamp == "" {
+		respondError(w, http.StatusBadRequest, "address, signature, and timestamp are required")
+		return
+	}
+
+	polyURL := fmt.Sprintf("%s/auth/api-key", h.polymarketBaseURL)
+	polyReq, err := http.NewRequestWithContext(r.Context(), http.MethodPost, polyURL, nil)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to build auth request")
+		return
+	}
+
+	polyReq.Header.Set("POLY_ADDRESS", req.Address)
+	polyReq.Header.Set("POLY_SIGNATURE", req.Signature)
+	polyReq.Header.Set("POLY_TIMESTAMP", req.Timestamp)
+	polyReq.Header.Set("POLY_NONCE", fmt.Sprintf("%d", req.Nonce))
+
+	resp, err := h.httpClient.Do(polyReq)
+	if err != nil {
+		log.Printf("[polymarket] auth relay error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to reach Polymarket auth service")
+		return
+	}
+	defer resp.Body.Close()
+
+	body, err := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
+	if err != nil {
+		respondError(w, http.StatusBadGateway, "failed to read Polymarket auth response")
+		return
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	w.WriteHeader(resp.StatusCode)
+	w.Write(body)
+}
+
+// DeriveAPIKey handles POST /api/v1/polymarket/auth/derive
+// Note: Client sends POST to Turbine, but Turbine sends GET to Polymarket.
+// Polymarket's derive-api-key is a GET endpoint; Turbine accepts POST to carry L1 signature in body.
+func (h *AuthHandler) DeriveAPIKey(w http.ResponseWriter, r *http.Request) {
+	var req AuthRequest
+	r.Body = http.MaxBytesReader(w, r.Body, 1024)
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		respondError(w, http.StatusBadRequest, "invalid request body")
+		return
+	}
+
+	if req.Address == "" || req.Signature == "" || req.Timestamp == "" {
+		respondError(w, http.StatusBadRequest, "address, signature, and timestamp are required")
+		return
+	}
+
+	polyURL := fmt.Sprintf("%s/auth/derive-api-key", h.polymarketBaseURL)
+	polyReq, err := http.NewRequestWithContext(r.Context(), http.MethodGet, polyURL, nil)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to build auth request")
+		return
+	}
+
+	polyReq.Header.Set("POLY_ADDRESS", req.Address)
+	polyReq.Header.Set("POLY_SIGNATURE", req.Signature)
+	polyReq.Header.Set("POLY_TIMESTAMP", req.Timestamp)
+	polyReq.Header.Set("POLY_NONCE", fmt.Sprintf("%d", req.Nonce))
+
+	resp, err := h.httpClient.Do(polyReq)
+	if err != nil {
+		log.Printf("[polymarket] auth derive error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to reach Polymarket auth service")
+		return
+	}
+	defer resp.Body.Close()
+
+	body, err := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
+	if err != nil {
+		respondError(w, http.StatusBadGateway, "failed to read Polymarket auth response")
+		return
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	w.WriteHeader(resp.StatusCode)
+	w.Write(body)
+}
diff --git a/api/internal/polymarket/auth_test.go b/api/internal/polymarket/auth_test.go
