@@ -0,0 +1,382 @@
+package polymarket
+
+import (
+	"context"
+	"encoding/json"
+	"log"
+	"net/http"
+	"strings"
+	"time"
+
+	"github.com/go-chi/chi/v5"
+)
+
+type ClientFactory interface {
+	NewClient(apiKey, secret, passphrase string) (PolymarketClient, error)
+}
+
+// DepositRelayer handles the on-chain permit + transferFrom for gasless deposits.
+type DepositRelayer interface {
+	RelayDeposit(ctx context.Context, req GaslessDepositRequest, depositAddress string) (txHash string, err error)
+}
+
+// GaslessDepositRequest is the request body for gasless Polymarket deposits.
+// User signs an EIP-2612 USDC permit off-chain, Turbine relays the permit + transfer.
+type GaslessDepositRequest struct {
+	Owner    string `json:"owner"`    // User's wallet address
+	Amount   string `json:"amount"`   // USDC amount (6 decimals, e.g. "1000000" = $1)
+	Deadline string `json:"deadline"` // Permit deadline (unix timestamp)
+	V        uint8  `json:"v"`        // Permit signature v
+	R        string `json:"r"`        // Permit signature r (0x-prefixed hex)
+	S        string `json:"s"`        // Permit signature s (0x-prefixed hex)
+}
+
+type Handler struct {
+	clientFactory  ClientFactory
+	depositRelayer DepositRelayer // Optional — nil if deposit relay not configured
+}
+
+func NewHandler(factory ClientFactory) *Handler {
+	return &Handler{clientFactory: factory}
+}
+
+// SetDepositRelayer injects the deposit relayer for gasless Polymarket deposits.
+func (h *Handler) SetDepositRelayer(dr DepositRelayer) {
+	h.depositRelayer = dr
+}
+
+func (h *Handler) ListMarkets(w http.ResponseWriter, r *http.Request) {
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	cursor := r.URL.Query().Get("next_cursor")
+
+	client, err := h.clientFactory.NewClient("", "", "")
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	result, err := client.ListMarkets(ctx, cursor)
+	if err != nil {
+		log.Printf("[polymarket] ListMarkets error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to fetch Polymarket markets")
+		return
+	}
+
+	markets := make([]PolymarketMarketResponse, len(result.Markets))
+	for i, m := range result.Markets {
+		markets[i] = ConvertMarketToResponse(m)
+	}
+
+	respondJSON(w, http.StatusOK, map[string]interface{}{
+		"markets":     markets,
+		"count":       len(markets),
+		"next_cursor": result.NextCursor,
+	})
+}
+
+func (h *Handler) GetOrderBook(w http.ResponseWriter, r *http.Request) {
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	tokenID := chi.URLParam(r, "marketId")
+	if tokenID == "" {
+		respondError(w, http.StatusBadRequest, "missing marketId")
+		return
+	}
+
+	client, err := h.clientFactory.NewClient("", "", "")
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	ob, err := client.GetOrderBook(ctx, tokenID)
+	if err != nil {
+		log.Printf("[polymarket] GetOrderBook error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to fetch Polymarket orderbook")
+		return
+	}
+
+	snapshot := ConvertOrderBookToSnapshot(tokenID, *ob)
+	respondJSON(w, http.StatusOK, snapshot)
+}
+
+func (h *Handler) SubmitOrder(w http.ResponseWriter, r *http.Request) {
+	apiKey, secret, passphrase, err := ExtractPolymarketCreds(r)
+	if err != nil {
+		respondError(w, http.StatusUnauthorized, err.Error())
+		return
+	}
+
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	var req CreateOrderRequest
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		respondError(w, http.StatusBadRequest, "invalid request body")
+		return
+	}
+
+	client, err := h.clientFactory.NewClient(apiKey, secret, passphrase)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	result, err := client.CreateOrder(ctx, req)
+	if err != nil {
+		log.Printf("[polymarket] CreateOrder error: %v", err)
+		status, msg := mapPolymarketError(err)
+		respondError(w, status, "failed to place Polymarket order: "+msg)
+		return
+	}
+
+	respondJSON(w, http.StatusOK, result)
+}
+
+func (h *Handler) CancelOrder(w http.ResponseWriter, r *http.Request) {
+	apiKey, secret, passphrase, err := ExtractPolymarketCreds(r)
+	if err != nil {
+		respondError(w, http.StatusUnauthorized, err.Error())
+		return
+	}
+
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	orderID := chi.URLParam(r, "hash")
+	if orderID == "" {
+		respondError(w, http.StatusBadRequest, "missing order ID")
+		return
+	}
+
+	client, err := h.clientFactory.NewClient(apiKey, secret, passphrase)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	if err := client.CancelOrder(ctx, orderID); err != nil {
+		log.Printf("[polymarket] CancelOrder error: %v", err)
+		status, msg := mapPolymarketError(err)
+		respondError(w, status, "failed to cancel Polymarket order: "+msg)
+		return
+	}
+
+	respondJSON(w, http.StatusOK, map[string]string{
+		"status":  "cancelled",
+		"orderID": orderID,
+	})
+}
+
+func (h *Handler) GetUserOrders(w http.ResponseWriter, r *http.Request) {
+	apiKey, secret, passphrase, err := ExtractPolymarketCreds(r)
+	if err != nil {
+		respondError(w, http.StatusUnauthorized, err.Error())
+		return
+	}
+
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	client, err := h.clientFactory.NewClient(apiKey, secret, passphrase)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	orders, err := client.GetOpenOrders(ctx)
+	if err != nil {
+		log.Printf("[polymarket] GetOpenOrders error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to fetch Polymarket orders")
+		return
+	}
+
+	respondJSON(w, http.StatusOK, map[string]interface{}{
+		"orders": orders,
+		"count":  len(orders),
+	})
+}
+
+func (h *Handler) GetUserPositions(w http.ResponseWriter, r *http.Request) {
+	apiKey, secret, passphrase, err := ExtractPolymarketCreds(r)
+	if err != nil {
+		respondError(w, http.StatusUnauthorized, err.Error())
+		return
+	}
+
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	client, err := h.clientFactory.NewClient(apiKey, secret, passphrase)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	balances, err := client.GetBalances(ctx)
+	if err != nil {
+		log.Printf("[polymarket] GetBalances error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to fetch Polymarket positions")
+		return
+	}
+
+	respondJSON(w, http.StatusOK, map[string]interface{}{
+		"positions": balances,
+		"count":     len(balances),
+	})
+}
+
+// GetDepositAddress handles POST /api/v1/polymarket/deposit-address
+// Returns the Polymarket deposit address for a given wallet.
+// The client then sends a standard ERC20 USDC transfer to this address on Polygon.
+// No Polymarket API credentials needed — just the wallet address.
+func (h *Handler) GetDepositAddress(w http.ResponseWriter, r *http.Request) {
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	var req struct {
+		Address string `json:"address"`
+	}
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil || req.Address == "" {
+		respondError(w, http.StatusBadRequest, "address is required")
+		return
+	}
+
+	client, err := h.clientFactory.NewClient("", "", "")
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	resp, err := client.GetDepositAddress(ctx, req.Address)
+	if err != nil {
+		log.Printf("[polymarket] GetDepositAddress error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to get Polymarket deposit address")
+		return
+	}
+
+	respondJSON(w, http.StatusOK, resp)
+}
+
+// GetDepositStatus handles GET /api/v1/polymarket/deposit-status/{address}
+// Returns the status of deposits for a given wallet address.
+func (h *Handler) GetDepositStatus(w http.ResponseWriter, r *http.Request) {
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	address := chi.URLParam(r, "address")
+	if address == "" {
+		respondError(w, http.StatusBadRequest, "address is required")
+		return
+	}
+
+	client, err := h.clientFactory.NewClient("", "", "")
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	resp, err := client.GetDepositStatus(ctx, address)
+	if err != nil {
+		log.Printf("[polymarket] GetDepositStatus error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to get deposit status")
+		return
+	}
+
+	respondJSON(w, http.StatusOK, resp)
+}
+
+// SubmitGaslessDeposit handles POST /api/v1/polymarket/deposit
+// Two-step gasless deposit: permit (approve) + transferFrom to Polymarket deposit address.
+// User signs an EIP-2612 USDC permit off-chain. Turbine relays both the permit and the
+// transfer, paying gas from its own hot wallet. Same pattern as existing gasless trading.
+func (h *Handler) SubmitGaslessDeposit(w http.ResponseWriter, r *http.Request) {
+	ctx, cancel := context.WithTimeout(r.Context(), 30*time.Second)
+	defer cancel()
+
+	var req GaslessDepositRequest
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		respondError(w, http.StatusBadRequest, "invalid request body")
+		return
+	}
+
+	if req.Owner == "" || req.Amount == "" {
+		respondError(w, http.StatusBadRequest, "owner and amount are required")
+		return
+	}
+	if req.V == 0 && req.R == "" && req.S == "" {
+		respondError(w, http.StatusBadRequest, "EIP-2612 permit signature (v, r, s) is required")
+		return
+	}
+
+	if h.depositRelayer == nil {
+		respondError(w, http.StatusNotImplemented, "Polymarket deposit relayer not configured")
+		return
+	}
+
+	// Step 1: Get the Polymarket deposit address for this user
+	client, err := h.clientFactory.NewClient("", "", "")
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to create Polymarket client")
+		return
+	}
+
+	depositAddr, err := client.GetDepositAddress(ctx, req.Owner)
+	if err != nil {
+		log.Printf("[polymarket] GetDepositAddress error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to get Polymarket deposit address")
+		return
+	}
+	if depositAddr.EVM == "" {
+		respondError(w, http.StatusBadGateway, "Polymarket returned empty deposit address")
+		return
+	}
+
+	// Step 2: Relay the permit + transferFrom via Turbine's relayer
+	txHash, err := h.depositRelayer.RelayDeposit(ctx, req, depositAddr.EVM)
+	if err != nil {
+		log.Printf("[polymarket] RelayDeposit error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to relay deposit: "+err.Error())
+		return
+	}
+
+	log.Printf("[polymarket] Gasless deposit relayed: owner=%s amount=%s deposit_addr=%s tx=%s",
+		req.Owner, req.Amount, depositAddr.EVM, txHash)
+
+	respondJSON(w, http.StatusOK, map[string]string{
+		"success":         "true",
+		"tx_hash":         txHash,
+		"deposit_address": depositAddr.EVM,
+	})
+}
+
+func mapPolymarketError(err error) (int, string) {
+	msg := err.Error()
+	switch {
+	case strings.Contains(msg, "rate limit") || strings.Contains(msg, "429"):
+		return http.StatusTooManyRequests, "Polymarket rate limit exceeded, try again later"
+	case strings.Contains(msg, "unauthorized") || strings.Contains(msg, "401"):
+		return http.StatusUnauthorized, "Polymarket credentials are invalid or expired"
+	case strings.Contains(msg, "forbidden") || strings.Contains(msg, "403"):
+		return http.StatusForbidden, "Polymarket access denied"
+	case strings.Contains(msg, "insufficient"):
+		return http.StatusBadRequest, "insufficient funds for this order"
+	default:
+		return http.StatusBadGateway, msg
+	}
+}
+
+func respondJSON(w http.ResponseWriter, status int, data interface{}) {
+	w.Header().Set("Content-Type", "application/json")
+	w.WriteHeader(status)
+	json.NewEncoder(w).Encode(data)
+}
+
+func respondError(w http.ResponseWriter, status int, message string) {
+	respondJSON(w, status, map[string]string{
+		"error": message,
+	})
+}
