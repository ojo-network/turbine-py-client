@@ -0,0 +1,86 @@
+package polymarket
+
+import (
+	"net/http/httptest"
+	"testing"
+)
+
+func TestExtractPolymarketCreds_Success(t *testing.T) {
+	r := httptest.NewRequest("GET", "/test", nil)
+	r.Header.Set("X-Polymarket-Key", "test-key")
+	r.Header.Set("X-Polymarket-Secret", "test-secret")
+	r.Header.Set("X-Polymarket-Passphrase", "test-passphrase")
+
+	key, secret, passphrase, err := ExtractPolymarketCreds(r)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if key != "test-key" || secret != "test-secret" || passphrase != "test-passphrase" {
+		t.Fatalf("got key=%s secret=%s passphrase=%s", key, secret, passphrase)
+	}
+
+	if r.Header.Get("X-Polymarket-Key") != "" {
+		t.Fatal("X-Polymarket-Key header not scrubbed")
+	}
+	if r.Header.Get("X-Polymarket-Secret") != "" {
+		t.Fatal("X-Polymarket-Secret header not scrubbed")
+	}
+	if r.Header.Get("X-Polymarket-Passphrase") != "" {
+		t.Fatal("X-Polymarket-Passphrase header not scrubbed")
+	}
+}
+
+func TestExtractPolymarketCreds_MissingKey(t *testing.T) {
+	r := httptest.NewRequest("GET", "/test", nil)
+	r.Header.Set("X-Polymarket-Secret", "test-secret")
+	r.Header.Set("X-Polymarket-Passphrase", "test-passphrase")
+
+	_, _, _, err := ExtractPolymarketCreds(r)
+	if err == nil {
+		t.Fatal("expected error for missing key")
+	}
+}
+
+func TestExtractPolymarketCreds_MissingSecret(t *testing.T) {
+	r := httptest.NewRequest("GET", "/test", nil)
+	r.Header.Set("X-Polymarket-Key", "test-key")
+	r.Header.Set("X-Polymarket-Passphrase", "test-passphrase")
+
+	_, _, _, err := ExtractPolymarketCreds(r)
+	if err == nil {
+		t.Fatal("expected error for missing secret")
+	}
+}
+
+func TestExtractPolymarketCreds_MissingPassphrase(t *testing.T) {
+	r := httptest.NewRequest("GET", "/test", nil)
+	r.Header.Set("X-Polymarket-Key", "test-key")
+	r.Header.Set("X-Polymarket-Secret", "test-secret")
+
+	_, _, _, err := ExtractPolymarketCreds(r)
+	if err == nil {
+		t.Fatal("expected error for missing passphrase")
+	}
+}
+
+func TestIsPolymarketRequest(t *testing.T) {
+	tests := []struct {
+		name     string
+		query    string
+		expected bool
+	}{
+		{"polymarket=true", "polymarket=true", true},
+		{"polymarket=false", "polymarket=false", false},
+		{"no param", "", false},
+		{"other param", "foo=bar", false},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			r := httptest.NewRequest("GET", "/test?"+tt.query, nil)
+			if got := IsPolymarketRequest(r); got != tt.expected {
+				t.Fatalf("IsPolymarketRequest() = %v, want %v", got, tt.expected)
+			}
+		})
+	}
+}
