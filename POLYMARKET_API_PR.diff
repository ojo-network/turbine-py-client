+
+	polymarket "github.com/GoPolymarket/polymarket-go-sdk"
+	"github.com/GoPolymarket/polymarket-go-sdk/pkg/auth"
+	"github.com/GoPolymarket/polymarket-go-sdk/pkg/bridge"
+	"github.com/GoPolymarket/polymarket-go-sdk/pkg/clob/clobtypes"
+	"github.com/GoPolymarket/polymarket-go-sdk/pkg/data"
+	"github.com/ethereum/go-ethereum/common"
+)
+
+// SDKClientFactory creates real Polymarket SDK clients from per-request credentials.
+type SDKClientFactory struct{}
+
+func NewSDKClientFactory() *SDKClientFactory {
+	return &SDKClientFactory{}
+}
+
+// NewClient creates an ephemeral Polymarket SDK client.
+// For public endpoints (empty credentials), returns an unauthenticated client.
+// For authenticated endpoints, creates a client with L2 (HMAC) auth via API key.
+func (f *SDKClientFactory) NewClient(apiKey, secret, passphrase string) (PolymarketClient, error) {
+	client := polymarket.NewClient()
+
+	if apiKey != "" && secret != "" && passphrase != "" {
+		creds := &auth.APIKey{
+			Key:        apiKey,
+			Secret:     secret,
+			Passphrase: passphrase,
+		}
+		// nil signer is fine — L2 operations (orders, cancel, balances) use HMAC auth
+		// from the API key, not EIP-712 signatures. The signer is only needed for L1
+		// operations like creating API keys, which we handle via the auth relay endpoint.
+		client = client.WithAuth(nil, creds)
+	}
+
+	return &sdkClient{client: client}, nil
+}
+
+// safeSignatureType is Gnosis Safe (2). Polymarket uses Safe wallets for all
+// new accounts, so balance/order queries need this signature type to hit the
+// correct wallet.
+var safeSignatureType = int(auth.SignatureGnosisSafe)
+
+type sdkClient struct {
+	client *polymarket.Client
+}
+
+// ListMarkets fetches markets from Polymarket's CLOB API.
+func (c *sdkClient) ListMarkets(ctx context.Context, nextCursor string) (*MarketsResponse, error) {
+	req := &clobtypes.MarketsRequest{
+		Limit: 100,
+	}
+	if nextCursor != "" {
+		req.Cursor = nextCursor
+	}
+
+	resp, err := c.client.CLOB.Markets(ctx, req)
+	if err != nil {
+		return nil, fmt.Errorf("polymarket markets: %w", err)
+	}
+
+	markets := make([]PolymarketMarket, len(resp.Data))
+	for i, m := range resp.Data {
+		vol, _ := strconv.ParseFloat(m.Volume, 64)
+		tokens := make([]Token, len(m.Tokens))
+		for j, t := range m.Tokens {
+			tokens[j] = Token{
+				TokenID: t.TokenID,
+				Outcome: t.Outcome,
+				Price:   t.Price,
+			}
+		}
+		markets[i] = PolymarketMarket{
+			ConditionID: m.ConditionID,
+			Question:    m.Question,
+			EndDate:     m.EndDate,
+			Volume:      vol,
+			Active:      m.Active,
+			Closed:      m.Closed,
+			Tokens:      tokens,
+		}
+	}
+
+	return &MarketsResponse{
+		Markets:    markets,
+		NextCursor: resp.NextCursor,
+	}, nil
+}
+
+// GetOrderBook fetches the L2 orderbook for a token.
+func (c *sdkClient) GetOrderBook(ctx context.Context, tokenID string) (*OrderBookResponse, error) {
+	req := &clobtypes.BookRequest{
+		TokenID: tokenID,
+	}
+
+	resp, err := c.client.CLOB.OrderBook(ctx, req)
+	if err != nil {
+		return nil, fmt.Errorf("polymarket orderbook: %w", err)
+	}
+
+	bids := make([]RawPriceLevel, len(resp.Bids))
+	for i, b := range resp.Bids {
+		bids[i] = RawPriceLevel{Price: b.Price, Size: b.Size}
+	}
+	asks := make([]RawPriceLevel, len(resp.Asks))
+	for i, a := range resp.Asks {
+		asks[i] = RawPriceLevel{Price: a.Price, Size: a.Size}
+	}
+
+	return &OrderBookResponse{Bids: bids, Asks: asks}, nil
+}
+
+// CreateOrder submits a pre-signed order to Polymarket via PostOrder.
+// The order must be signed client-side — Turbine never has access to private keys.
+func (c *sdkClient) CreateOrder(ctx context.Context, order CreateOrderRequest) (*OrderResponse, error) {
+	if len(order.SignedOrder) == 0 {
+		return nil, fmt.Errorf("signed_order is required: client must sign the order locally and include the full signed payload")
+	}
+
+	var signedOrder clobtypes.SignedOrder
+	if err := json.Unmarshal(order.SignedOrder, &signedOrder); err != nil {
+		return nil, fmt.Errorf("invalid signed_order: %w", err)
+	}
+
+	resp, err := c.client.CLOB.WithSignatureType(auth.SignatureGnosisSafe).PostOrder(ctx, &signedOrder)
+	if err != nil {
+		return nil, fmt.Errorf("polymarket post order: %w", err)
+	}
+
+	return &OrderResponse{
+		ID:        resp.ID,
+		Status:    resp.Status,
+		TokenID:   resp.AssetID,
+		Side:      resp.Side,
+		Price:     resp.Price,
+		Size:      resp.OriginalSize,
+		OrderType: resp.OrderType,
+	}, nil
+}
+
+// CancelOrder cancels an order on Polymarket.
+func (c *sdkClient) CancelOrder(ctx context.Context, orderID string) error {
+	req := &clobtypes.CancelOrderRequest{
+		OrderID: orderID,
+	}
+
+	_, err := c.client.CLOB.WithSignatureType(auth.SignatureGnosisSafe).CancelOrder(ctx, req)
+	if err != nil {
+		return fmt.Errorf("polymarket cancel order: %w", err)
+	}
+	return nil
+}
+
+// GetOpenOrders fetches the user's open orders from their Safe wallet.
+func (c *sdkClient) GetOpenOrders(ctx context.Context) ([]*OrderResponse, error) {
+	resp, err := c.client.CLOB.WithSignatureType(auth.SignatureGnosisSafe).Orders(ctx, &clobtypes.OrdersRequest{})
+	if err != nil {
+		return nil, fmt.Errorf("polymarket orders: %w", err)
+	}
+
+	orders := make([]*OrderResponse, len(resp.Data))
+	for i, o := range resp.Data {
+		orders[i] = &OrderResponse{
+			ID:        o.ID,
+			Status:    o.Status,
+			TokenID:   o.AssetID,
+			Side:      o.Side,
+			Price:     o.Price,
+			Size:      o.OriginalSize,
+			OrderType: o.OrderType,
+		}
+	}
+	return orders, nil
+}
+
+// GetBalances fetches the user's USDC (collateral) balance from their Safe wallet.
+func (c *sdkClient) GetBalances(ctx context.Context) ([]*BalanceResponse, error) {
+	req := &clobtypes.BalanceAllowanceRequest{
+		AssetType:     clobtypes.AssetTypeCollateral,
+		SignatureType: &safeSignatureType,
+	}
+
+	resp, err := c.client.CLOB.WithSignatureType(auth.SignatureGnosisSafe).BalanceAllowance(ctx, req)
+	if err != nil {
+		return nil, fmt.Errorf("polymarket balance: %w", err)
+	}
+
+	return []*BalanceResponse{
+		{
+			TokenID: "USDC",
+			Balance: resp.Balance,
+		},
+	}, nil
+}
+
+// GetPositions fetches user's open positions from Polymarket's Data API.
+// Automatically derives the Safe wallet from the EOA since Polymarket stores
+// positions in Safe wallets, not EOAs.
+func (c *sdkClient) GetPositions(ctx context.Context, walletAddress string) ([]*PositionResponse, error) {
+	eoa := common.HexToAddress(walletAddress)
+
+	// Derive Safe wallet — positions live here, not on the EOA
+	safeAddr, err := auth.DeriveSafeWallet(eoa)
+	if err != nil {
+		// Fallback to EOA if derivation fails
+		safeAddr = eoa
+	}
+
+	resp, err := c.client.Data.Positions(ctx, &data.PositionsRequest{
+		User: safeAddr,
+	})
+	if err != nil {
+		return nil, fmt.Errorf("polymarket positions: %w", err)
+	}
+
+	positions := make([]*PositionResponse, len(resp))
+	for i, p := range resp {
+		positions[i] = &PositionResponse{
+			ConditionID:  p.ConditionID.Hex(),
+			Asset:        p.Asset.String(),
+			Size:         p.Size.String(),
+			AvgPrice:     p.AvgPrice.String(),
+			CurrentValue: p.CurrentValue.String(),
+			InitialValue: p.InitialValue.String(),
+			PnL:          p.CashPnl.String(),
+			PnLPercent:   p.PercentPnl.String(),
+			Outcome:      p.Outcome,
+			Title:        p.Title,
+			Redeemable:   p.Redeemable,
+		}
+	}
+	return positions, nil
+}
+
+// GetDepositAddress returns the Polymarket deposit address for a wallet.
+func (c *sdkClient) GetDepositAddress(ctx context.Context, walletAddress string) (*DepositAddressResponse, error) {
+	resp, err := c.client.Bridge.DepositAddress(ctx, &bridge.DepositRequest{
+		Address: walletAddress,
+	})
+	if err != nil {
+		return nil, fmt.Errorf("polymarket deposit address: %w", err)
+	}
+
+	return &DepositAddressResponse{
+		EVM:  resp.Address.EVM,
+		SVM:  resp.Address.SVM,
+		BTC:  resp.Address.BTC,
+		Note: resp.Note,
+	}, nil
+}
+
+// GetDepositStatus returns deposit transaction status for a wallet.
+func (c *sdkClient) GetDepositStatus(ctx context.Context, walletAddress string) (*DepositStatusResponse, error) {
+	resp, err := c.client.Bridge.Status(ctx, &bridge.StatusRequest{
+		Address: walletAddress,
+	})
+	if err != nil {
+		return nil, fmt.Errorf("polymarket deposit status: %w", err)
+	}
+
+	txs := make([]DepositTransaction, len(resp.Transactions))
+	for i, t := range resp.Transactions {
+		txs[i] = DepositTransaction{
+			FromChainID: t.FromChainID,
+			FromToken:   t.FromTokenAddress,
+			FromAmount:  t.FromAmountBaseUnit,
+			ToChainID:   t.ToChainID,
+			ToToken:     t.ToTokenAddress,
+			Status:      t.Status,
+			TxHash:      t.TxHash,
+		}
+	}
+
+	return &DepositStatusResponse{Transactions: txs}, nil
+}
