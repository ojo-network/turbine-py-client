+++ b/api/internal/polymarket/onboard.go
@@ -0,0 +1,393 @@
+package polymarket
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"log"
+	"math/big"
+	"net/http"
+	"os"
+
+	"github.com/GoPolymarket/polymarket-go-sdk/pkg/auth"
+	"github.com/ethereum/go-ethereum/common"
+	"github.com/ethereum/go-ethereum/crypto"
+)
+
+// Polymarket contract addresses on Polygon mainnet
+var (
+	PolymarketExchange     = common.HexToAddress("0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E")
+	PolymarketNegRisk      = common.HexToAddress("0xC5d563A36AE78145C45a50134d48A1215220f80a")
+	PolymarketUSDC         = common.HexToAddress("0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174")
+	PolymarketCTF          = common.HexToAddress("0x4D97DCd97eC945f40cF65F87097ACe5EA0476045")
+	PolymarketRelayerURL   = "https://relayer-v2.polymarket.com"
+)
+
+// OnboardingStatus represents the full state of a user's Polymarket setup.
+type OnboardingStatus struct {
+	EOA        string `json:"eoa"`
+	SafeWallet string `json:"safe_wallet"`
+
+	// Onboarding stages
+	SafeDeployed       bool `json:"safe_deployed"`
+	USDCApproved       bool `json:"usdc_exchange_approved"`
+	USDCNegRiskApproved bool `json:"usdc_neg_risk_approved"`
+	CTFApproved        bool `json:"ctf_exchange_approved"`
+	CTFNegRiskApproved bool `json:"ctf_neg_risk_approved"`
+
+	// Human-readable stage
+	Stage    string `json:"stage"`    // "deploy_safe", "approve_usdc", "approve_ctf", "ready"
+	NextStep string `json:"next_step"` // Description of what to do next
+	Ready    bool   `json:"ready"`    // True if all steps are complete
+}
+
+// OnboardHandler handles Polymarket user onboarding.
+type OnboardHandler struct {
+	relayerURL string
+	httpClient *http.Client
+}
+
+func NewOnboardHandler() *OnboardHandler {
+	return &OnboardHandler{
+		relayerURL: PolymarketRelayerURL,
+		httpClient: &http.Client{Timeout: SDKTimeout},
+	}
+}
+
+// GetOnboardingStatus handles GET /api/v1/polymarket/onboard/status?address=0x...
+// Returns the full onboarding state: Safe deployment, USDC allowances, CTF approvals.
+func (h *OnboardHandler) GetOnboardingStatus(w http.ResponseWriter, r *http.Request) {
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	address := r.URL.Query().Get("address")
+	if address == "" || !common.IsHexAddress(address) {
+		respondError(w, http.StatusBadRequest, "valid address query param is required")
+		return
+	}
+
+	eoa := common.HexToAddress(address)
+	safeAddr, err := auth.DeriveSafeWallet(eoa)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to derive safe wallet: "+err.Error())
+		return
+	}
+
+	status := OnboardingStatus{
+		EOA:        eoa.Hex(),
+		SafeWallet: safeAddr.Hex(),
+	}
+
+	// Step 1: Check Safe deployment
+	deployed, err := h.isSafeDeployed(ctx, safeAddr)
+	if err != nil {
+		log.Printf("[polymarket] check safe deployed error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to check Safe deployment status")
+		return
+	}
+	status.SafeDeployed = deployed
+
+	if !deployed {
+		status.Stage = "deploy_safe"
+		status.NextStep = "Deploy Safe wallet via POST /polymarket/onboard/relay"
+		respondJSON(w, http.StatusOK, status)
+		return
+	}
+
+	// Step 2: Check USDC allowances (only if Safe is deployed)
+	status.USDCApproved = h.checkERC20Allowance(ctx, PolymarketUSDC, safeAddr, PolymarketExchange)
+	status.USDCNegRiskApproved = h.checkERC20Allowance(ctx, PolymarketUSDC, safeAddr, PolymarketNegRisk)
+
+	if !status.USDCApproved || !status.USDCNegRiskApproved {
+		status.Stage = "approve_usdc"
+		status.NextStep = "Approve USDC spending for exchange contracts via POST /polymarket/onboard/relay"
+		respondJSON(w, http.StatusOK, status)
+		return
+	}
+
+	// Step 3: Check CTF approvals
+	status.CTFApproved = h.checkCTFApproval(ctx, PolymarketCTF, safeAddr, PolymarketExchange)
+	status.CTFNegRiskApproved = h.checkCTFApproval(ctx, PolymarketCTF, safeAddr, PolymarketNegRisk)
+
+	if !status.CTFApproved || !status.CTFNegRiskApproved {
+		status.Stage = "approve_ctf"
+		status.NextStep = "Approve CTF (conditional tokens) for exchange contracts via POST /polymarket/onboard/relay"
+		respondJSON(w, http.StatusOK, status)
+		return
+	}
+
+	// All done
+	status.Stage = "ready"
+	status.NextStep = "Create API key via POST /polymarket/auth, then trade!"
+	status.Ready = true
+	respondJSON(w, http.StatusOK, status)
+}
+
+// GetSafeWallet handles GET /api/v1/polymarket/onboard/safe-wallet?address=0x...
+// Derives and returns the Safe wallet address for an EOA.
+func (h *OnboardHandler) GetSafeWallet(w http.ResponseWriter, r *http.Request) {
+	address := r.URL.Query().Get("address")
+	if address == "" || !common.IsHexAddress(address) {
+		respondError(w, http.StatusBadRequest, "valid address query param is required")
+		return
+	}
+
+	eoa := common.HexToAddress(address)
+	safeAddr, err := auth.DeriveSafeWallet(eoa)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to derive safe wallet: "+err.Error())
+		return
+	}
+
+	respondJSON(w, http.StatusOK, map[string]string{
+		"eoa":         eoa.Hex(),
+		"safe_wallet": safeAddr.Hex(),
+	})
+}
+
+// SubmitRelayerTx handles POST /api/v1/polymarket/onboard/relay
+// Forwards a pre-signed Safe transaction to Polymarket's relayer.
+// Used for: Safe deployment, USDC approval, CTF approval.
+// The client builds and signs the Safe transaction, Turbine forwards it.
+func (h *OnboardHandler) SubmitRelayerTx(w http.ResponseWriter, r *http.Request) {
+	ctx, cancel := context.WithTimeout(r.Context(), 30*SDKTimeout)
+	defer cancel()
+
+	// Read the raw request body and forward to Polymarket's relayer
+	r.Body = http.MaxBytesReader(w, r.Body, 10*1024) // 10KB limit
+	body, err := io.ReadAll(r.Body)
+	if err != nil {
+		respondError(w, http.StatusBadRequest, "failed to read request body")
+		return
+	}
+
+	// Validate it's valid JSON
+	var check map[string]interface{}
+	if err := json.Unmarshal(body, &check); err != nil {
+		respondError(w, http.StatusBadRequest, "invalid JSON body")
+		return
+	}
+
+	// Validate required fields
+	requiredFields := []string{"from", "to", "data", "signature", "type"}
+	for _, field := range requiredFields {
+		if _, ok := check[field]; !ok {
+			respondError(w, http.StatusBadRequest, fmt.Sprintf("missing required field: %s", field))
+			return
+		}
+	}
+
+	// Forward to Polymarket's relayer
+	relayURL := fmt.Sprintf("%s/submit", h.relayerURL)
+	relayReq, err := http.NewRequestWithContext(ctx, http.MethodPost, relayURL, io.NopCloser(
+		jsonReader(body),
+	))
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to build relay request")
+		return
+	}
+	relayReq.Header.Set("Content-Type", "application/json")
+
+	// Forward any Polymarket auth headers the client sends
+	for _, header := range []string{"POLY_BUILDER_API_KEY", "POLY_BUILDER_TIMESTAMP", "POLY_BUILDER_PASSPHRASE", "POLY_BUILDER_SIGNATURE", "RELAYER_API_KEY", "RELAYER_API_KEY_ADDRESS"} {
+		if v := r.Header.Get(header); v != "" {
+			relayReq.Header.Set(header, v)
+		}
+	}
+
+	resp, err := h.httpClient.Do(relayReq)
+	if err != nil {
+		log.Printf("[polymarket] relayer submit error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to reach Polymarket relayer")
+		return
+	}
+	defer resp.Body.Close()
+
+	respBody, err := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
+	if err != nil {
+		respondError(w, http.StatusBadGateway, "failed to read relayer response")
+		return
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	w.WriteHeader(resp.StatusCode)
+	w.Write(respBody)
+}
+
+// GetRelayerNonce handles GET /api/v1/polymarket/onboard/nonce?address=0x...&type=SAFE
+// Returns the relayer address and current nonce for building Safe transactions.
+func (h *OnboardHandler) GetRelayerNonce(w http.ResponseWriter, r *http.Request) {
+	ctx, cancel := context.WithTimeout(r.Context(), SDKTimeout)
+	defer cancel()
+
+	address := r.URL.Query().Get("address")
+	txType := r.URL.Query().Get("type")
+	if address == "" {
+		respondError(w, http.StatusBadRequest, "address query param is required")
+		return
+	}
+	if txType == "" {
+		txType = "SAFE"
+	}
+
+	url := fmt.Sprintf("%s/relay-payload?address=%s&type=%s", h.relayerURL, address, txType)
+	req, err := http.NewRequestWithContext(ctx, http.MethodGet, url, nil)
+	if err != nil {
+		respondError(w, http.StatusInternalServerError, "failed to build request")
+		return
+	}
+
+	resp, err := h.httpClient.Do(req)
+	if err != nil {
+		log.Printf("[polymarket] relayer nonce error: %v", err)
+		respondError(w, http.StatusBadGateway, "failed to reach Polymarket relayer")
+		return
+	}
+	defer resp.Body.Close()
+
+	body, err := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
+	if err != nil {
+		respondError(w, http.StatusBadGateway, "failed to read relayer response")
+		return
+	}
+
+	w.Header().Set("Content-Type", "application/json")
+	w.WriteHeader(resp.StatusCode)
+	w.Write(body)
+}
+
+// GetContractAddresses handles GET /api/v1/polymarket/onboard/contracts
+// Returns the Polymarket contract addresses needed for approvals.
+func (h *OnboardHandler) GetContractAddresses(w http.ResponseWriter, r *http.Request) {
+	respondJSON(w, http.StatusOK, map[string]string{
+		"exchange":       PolymarketExchange.Hex(),
+		"neg_risk":       PolymarketNegRisk.Hex(),
+		"usdc":           PolymarketUSDC.Hex(),
+		"ctf":            PolymarketCTF.Hex(),
+		"relayer":        PolymarketRelayerURL,
+	})
+}
+
+func (h *OnboardHandler) isSafeDeployed(ctx context.Context, safeAddr common.Address) (bool, error) {
+	url := fmt.Sprintf("%s/deployed?address=%s", h.relayerURL, safeAddr.Hex())
+	req, err := http.NewRequestWithContext(ctx, http.MethodGet, url, nil)
+	if err != nil {
+		return false, err
+	}
+
+	resp, err := h.httpClient.Do(req)
+	if err != nil {
+		return false, err
+	}
+	defer resp.Body.Close()
+
+	var result struct {
+		Deployed bool `json:"deployed"`
+	}
+	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
+		return false, err
+	}
+	return result.Deployed, nil
+}
+
+// checkERC20Allowance checks if owner has approved spender for any amount of the token.
+func (h *OnboardHandler) checkERC20Allowance(ctx context.Context, token, owner, spender common.Address) bool {
+	// allowance(address,address) selector
+	selector := crypto.Keccak256([]byte("allowance(address,address)"))[:4]
+	data := make([]byte, 0, 68)
+	data = append(data, selector...)
+	data = append(data, common.LeftPadBytes(owner.Bytes(), 32)...)
+	data = append(data, common.LeftPadBytes(spender.Bytes(), 32)...)
+
+	result, err := h.ethCall(ctx, token, data)
+	if err != nil {
+		log.Printf("[polymarket] checkERC20Allowance error: %v", err)
+		return false
+	}
+
+	allowance := new(big.Int).SetBytes(result)
+	return allowance.Sign() > 0
+}
+
+// checkCTFApproval checks if owner has setApprovalForAll for operator on the CTF contract.
+func (h *OnboardHandler) checkCTFApproval(ctx context.Context, ctfAddr, owner, operator common.Address) bool {
+	// isApprovedForAll(address,address) selector
+	selector := crypto.Keccak256([]byte("isApprovedForAll(address,address)"))[:4]
+	data := make([]byte, 0, 68)
+	data = append(data, selector...)
+	data = append(data, common.LeftPadBytes(owner.Bytes(), 32)...)
+	data = append(data, common.LeftPadBytes(operator.Bytes(), 32)...)
+
+	result, err := h.ethCall(ctx, ctfAddr, data)
+	if err != nil {
+		log.Printf("[polymarket] checkCTFApproval error: %v", err)
+		return false
+	}
+
+	return new(big.Int).SetBytes(result).Int64() == 1
+}
+
+// ethCall performs a read-only eth_call against a Polygon RPC.
+func (h *OnboardHandler) ethCall(ctx context.Context, to common.Address, calldata []byte) ([]byte, error) {
+	rpcURL := os.Getenv("POLYGON_RPC_URL")
+	if rpcURL == "" {
+		rpcURL = "https://polygon.drpc.org"
+	}
+
+	payload := fmt.Sprintf(`{"jsonrpc":"2.0","method":"eth_call","params":[{"to":"%s","data":"0x%x"},"latest"],"id":1}`,
+		to.Hex(), calldata)
+
+	req, err := http.NewRequestWithContext(ctx, "POST", rpcURL, bytesReader([]byte(payload)))
+	if err != nil {
+		return nil, err
+	}
+	req.Header.Set("Content-Type", "application/json")
+
+	resp, err := h.httpClient.Do(req)
+	if err != nil {
+		return nil, err
+	}
+	defer resp.Body.Close()
+
+	body, err := io.ReadAll(resp.Body)
+	if err != nil {
+		return nil, err
+	}
+
+	var rpcResp struct {
+		Result string          `json:"result"`
+		Error  json.RawMessage `json:"error"`
+	}
+	if err := json.Unmarshal(body, &rpcResp); err != nil {
+		return nil, fmt.Errorf("bad rpc response: %s", string(body))
+	}
+	if len(rpcResp.Error) > 0 && string(rpcResp.Error) != "null" {
+		return nil, fmt.Errorf("rpc error: %s", string(rpcResp.Error))
+	}
+
+	return common.FromHex(rpcResp.Result), nil
+}
+
+// jsonReader wraps bytes in a reader for http request body
+func jsonReader(data []byte) io.Reader {
+	return io.NopCloser(bytesReader(data))
+}
+
+type bytesReaderImpl struct {
+	data []byte
+	pos  int
+}
+
+func bytesReader(data []byte) *bytesReaderImpl {
+	return &bytesReaderImpl{data: data}
+}
+
+func (r *bytesReaderImpl) Read(p []byte) (n int, err error) {
+	if r.pos >= len(r.data) {
+		return 0, io.EOF
+	}
+	n = copy(p, r.data[r.pos:])
+	r.pos += n
+	return
+}
