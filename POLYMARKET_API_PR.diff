+++ b/api/internal/polymarket/auth_test.go
@@ -0,0 +1,98 @@
+package polymarket
+
+import (
+	"encoding/json"
+	"net/http"
+	"net/http/httptest"
+	"strings"
+	"testing"
+)
+
+func TestAuthHandler_MissingFields(t *testing.T) {
+	ah := NewAuthHandler("https://clob.polymarket.com")
+
+	body := `{"address": "0x123"}`
+	r := httptest.NewRequest("POST", "/api/v1/polymarket/auth", strings.NewReader(body))
+	w := httptest.NewRecorder()
+
+	ah.CreateAPIKey(w, r)
+
+	if w.Code != http.StatusBadRequest {
+		t.Fatalf("status = %d, want 400. body: %s", w.Code, w.Body.String())
+	}
+}
+
+func TestAuthHandler_InvalidJSON(t *testing.T) {
+	ah := NewAuthHandler("https://clob.polymarket.com")
+
+	r := httptest.NewRequest("POST", "/api/v1/polymarket/auth", strings.NewReader("not json"))
+	w := httptest.NewRecorder()
+
+	ah.CreateAPIKey(w, r)
+
+	if w.Code != http.StatusBadRequest {
+		t.Fatalf("status = %d, want 400", w.Code)
+	}
+}
+
+func TestAuthHandler_PolymarketRelay(t *testing.T) {
+	mockPoly := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		if r.Header.Get("POLY_ADDRESS") != "0xuser" {
+			t.Errorf("POLY_ADDRESS = %s, want 0xuser", r.Header.Get("POLY_ADDRESS"))
+		}
+		if r.Header.Get("POLY_SIGNATURE") != "0xsig" {
+			t.Errorf("POLY_SIGNATURE = %s, want 0xsig", r.Header.Get("POLY_SIGNATURE"))
+		}
+
+		w.Header().Set("Content-Type", "application/json")
+		json.NewEncoder(w).Encode(map[string]string{
+			"apiKey":     "new-key",
+			"secret":     "new-secret",
+			"passphrase": "new-pass",
+		})
+	}))
+	defer mockPoly.Close()
+
+	ah := NewAuthHandler(mockPoly.URL)
+
+	body := `{"address":"0xuser","signature":"0xsig","timestamp":"1711100000","nonce":0}`
+	r := httptest.NewRequest("POST", "/api/v1/polymarket/auth", strings.NewReader(body))
+	w := httptest.NewRecorder()
+
+	ah.CreateAPIKey(w, r)
+
+	if w.Code != http.StatusOK {
+		t.Fatalf("status = %d, want 200. body: %s", w.Code, w.Body.String())
+	}
+
+	var resp map[string]string
+	json.NewDecoder(w.Body).Decode(&resp)
+
+	if resp["apiKey"] != "new-key" {
+		t.Errorf("apiKey = %s, want new-key", resp["apiKey"])
+	}
+	if resp["secret"] != "new-secret" {
+		t.Errorf("secret = %s, want new-secret", resp["secret"])
+	}
+}
+
+func TestAuthHandler_PolymarketReturns403(t *testing.T) {
+	mockPoly := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.Header().Set("Content-Type", "application/json")
+		w.WriteHeader(http.StatusForbidden)
+		json.NewEncoder(w).Encode(map[string]string{"error": "invalid signature"})
+	}))
+	defer mockPoly.Close()
+
+	ah := NewAuthHandler(mockPoly.URL)
+
+	body := `{"address":"0xuser","signature":"0xbadsig","timestamp":"1711100000","nonce":0}`
+	r := httptest.NewRequest("POST", "/api/v1/polymarket/auth", strings.NewReader(body))
+	w := httptest.NewRecorder()
+
+	ah.CreateAPIKey(w, r)
+
+	if w.Code != http.StatusForbidden {
+		t.Fatalf("status = %d, want 403. body: %s", w.Code, w.Body.String())
+	}
+}
diff --git a/api/internal/polymarket/client.go b/api/internal/polymarket/client.go
new file mode 100644
index 0000000..195277b
--- /dev/null
+++ b/api/internal/polymarket/client.go
@@ -0,0 +1,144 @@
+package polymarket
+
+import (
+	"context"
+	"encoding/json"
+	"errors"
+	"net/http"
+	"strings"
+	"time"
+)
+
+const (
+	SDKTimeout = 15 * time.Second
+)
+
+type PolymarketClient interface {
+	ListMarkets(ctx context.Context, nextCursor string) (*MarketsResponse, error)
+	GetOrderBook(ctx context.Context, tokenID string) (*OrderBookResponse, error)
+	CreateOrder(ctx context.Context, order CreateOrderRequest) (*OrderResponse, error)
+	CancelOrder(ctx context.Context, orderID string) error
+	GetOpenOrders(ctx context.Context) ([]*OrderResponse, error)
+	GetBalances(ctx context.Context) ([]*BalanceResponse, error)
+	GetPositions(ctx context.Context, walletAddress string) ([]*PositionResponse, error)
+	GetDepositAddress(ctx context.Context, walletAddress string) (*DepositAddressResponse, error)
+	GetDepositStatus(ctx context.Context, walletAddress string) (*DepositStatusResponse, error)
+}
+
+type PositionResponse struct {
+	ConditionID  string `json:"condition_id"`
+	Asset        string `json:"asset"`
+	Size         string `json:"size"`
+	AvgPrice     string `json:"avg_price"`
+	CurrentValue string `json:"current_value"`
+	InitialValue string `json:"initial_value"`
+	PnL          string `json:"pnl"`
+	PnLPercent   string `json:"pnl_percent"`
+	Outcome      string `json:"outcome"`
+	Title        string `json:"title"`
+	Redeemable   bool   `json:"redeemable"`
+}
+
+type DepositAddressResponse struct {
+	EVM  string `json:"evm"`
+	SVM  string `json:"svm,omitempty"`
+	BTC  string `json:"btc,omitempty"`
+	Note string `json:"note,omitempty"`
+}
+
+type DepositStatusResponse struct {
+	Transactions []DepositTransaction `json:"transactions"`
+}
+
+type DepositTransaction struct {
+	FromChainID string `json:"from_chain_id"`
+	FromToken   string `json:"from_token_address"`
+	FromAmount  string `json:"from_amount"`
+	ToChainID   string `json:"to_chain_id"`
+	ToToken     string `json:"to_token_address"`
+	Status      string `json:"status"`
+	TxHash      string `json:"tx_hash,omitempty"`
+}
+
+type MarketsResponse struct {
+	Markets    []PolymarketMarket `json:"markets"`
+	NextCursor string             `json:"next_cursor"`
+}
+
+type PolymarketMarket struct {
+	ConditionID string  `json:"condition_id"`
+	Question    string  `json:"question"`
+	Description string  `json:"description"`
+	Category    string  `json:"category"`
+	EndDate     string  `json:"end_date"`
+	Volume      float64 `json:"volume"`
+	Active      bool    `json:"active"`
+	Closed      bool    `json:"closed"`
+	Tokens      []Token `json:"tokens"`
+}
+
+type Token struct {
+	TokenID string  `json:"token_id"`
+	Outcome string  `json:"outcome"`
+	Price   float64 `json:"price"`
+}
+
+type OrderBookResponse struct {
+	Bids []RawPriceLevel `json:"bids"`
+	Asks []RawPriceLevel `json:"asks"`
+}
+
+type RawPriceLevel struct {
+	Price string `json:"price"`
+	Size  string `json:"size"`
+}
+
+// CreateOrderRequest represents a pre-signed Polymarket order.
+// The client (bot SDK) builds and signs the order locally using the polymarket-go-sdk,
+// then sends the full signed payload through Turbine. Turbine never has the private key.
+type CreateOrderRequest struct {
+	// Simplified fields for basic order info (used by handler for logging/response)
+	TokenID   string `json:"token_id"`
+	Side      string `json:"side"`
+	Price     string `json:"price"`
+	Size      string `json:"size"`
+	OrderType string `json:"order_type"`
+
+	// The full pre-signed order payload from the Polymarket SDK.
+	// This is the complete SignedOrder that gets forwarded to PostOrder.
+	SignedOrder json.RawMessage `json:"signed_order"`
+}
+
+type OrderResponse struct {
+	ID        string `json:"id"`
+	Status    string `json:"status"`
+	TokenID   string `json:"token_id"`
+	Side      string `json:"side"`
+	Price     string `json:"price"`
+	Size      string `json:"size"`
+	OrderType string `json:"order_type"`
+}
+
+type BalanceResponse struct {
+	TokenID string `json:"token_id"`
+	Balance string `json:"balance"`
+}
+
+func IsPolymarketRequest(r *http.Request) bool {
+	return r.URL.Query().Get("polymarket") == "true"
+}
+
+func ExtractPolymarketCreds(r *http.Request) (apiKey, secret, passphrase string, err error) {
+	apiKey = strings.TrimSpace(r.Header.Get("X-Polymarket-Key"))
+	secret = strings.TrimSpace(r.Header.Get("X-Polymarket-Secret"))
+	passphrase = strings.TrimSpace(r.Header.Get("X-Polymarket-Passphrase"))
+
+	r.Header.Del("X-Polymarket-Key")
+	r.Header.Del("X-Polymarket-Secret")
+	r.Header.Del("X-Polymarket-Passphrase")
+
+	if apiKey == "" || secret == "" || passphrase == "" {
+		return "", "", "", errors.New("missing Polymarket credentials: X-Polymarket-Key, X-Polymarket-Secret, and X-Polymarket-Passphrase headers are required")
+	}
+	return
+}
